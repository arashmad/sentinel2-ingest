# Copy this file to .env and fill in real credentials locally.
# Never commit real credentials.

# Required Sentinel Hub credentials
SENTINEL2_INGEST_SENTINEL_HUB_CLIENT_ID=your-client-id
SENTINEL2_INGEST_SENTINEL_HUB_CLIENT_SECRET=your-client-secret

# Optional Sentinel Hub endpoints
# Leave these unset unless you need to override the package defaults.
SENTINEL2_INGEST_SENTINEL_HUB_BASE_URL=
SENTINEL2_INGEST_SENTINEL_HUB_TOKEN_URL=